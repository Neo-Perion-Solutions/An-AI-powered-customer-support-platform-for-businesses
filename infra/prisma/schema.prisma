generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp"), pgcrypto]
}

// =====================================================
// ENUMS
// =====================================================

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

enum ConversationStatus {
  OPEN
  AI_HANDLING
  ESCALATED
  WAITING_AGENT
  RESOLVED
  CLOSED
}

enum MessageRole {
  CUSTOMER
  AGENT
  AI
  SYSTEM
}

enum MessageChannel {
  WEB
  WHATSAPP
  EMAIL
  API
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  WAITING_AGENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AgentStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  TICKET_ASSIGNED
  TICKET_MENTION
  CONVERSATION_ESCALATED
  PAYMENT_FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  PERMISSION_CHANGE
}

enum KnowledgeSourceType {
  PDF
  DOCX
  TXT
  URL
  FAQ
}

enum KnowledgeSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// =====================================================
// AUTH & TENANCY
// =====================================================

model Organization {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  slug        String   @unique
  plan        PlanTier @default(FREE)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users                UserOrganizationRole[]
  customers            Customer[]
  conversations        Conversation[]
  messages             Message[]
  attachments          Attachment[]
  knowledgeSources     KnowledgeSource[]
  knowledgeChunks      KnowledgeChunk[]
  faqs                 Faq[]
  tickets              Ticket[]
  ticketComments       TicketComment[]
  agents               Agent[]
  agentStatusHistory   AgentStatusHistory[]
  whatsappAccounts     WhatsappAccount[]
  whatsappMessages     WhatsappMessage[]
  campaigns            Campaign[]
  notifications        Notification[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  roles                Role[]
  chatbotConfig        ChatbotConfig?

  @@index([slug])
}

model User {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  emailVerified Boolean @default(false)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizations UserOrganizationRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  agent         Agent?
  notifications Notification[]
  ticketComments TicketComment[]
  assignedTickets Ticket[] @relation("TicketAssignee")

  @@index([email])
}

model Role {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  description    String?
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions  RolePermission[]
  users        UserOrganizationRole[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key         String   @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String @db.Uuid
  permissionId String @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model UserOrganizationRole {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @db.Uuid
  organizationId String   @db.Uuid
  roleId         String   @db.Uuid
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model RefreshToken {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @db.Uuid
  organizationId String?  @db.Uuid
  tokenHash      String   @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

// =====================================================
// CUSTOMERS & CONVERSATIONS
// =====================================================

model Customer {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  externalId     String?
  name           String?
  email          String?
  phone          String?
  avatarUrl      String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([organizationId, externalId])
  @@index([organizationId, createdAt])
  @@index([organizationId, email])
}

model Conversation {
  id             String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String            @db.Uuid
  customerId     String            @db.Uuid
  assignedAgentId String?          @db.Uuid
  status         ConversationStatus @default(OPEN)
  channel        MessageChannel    @default(WEB)
  subject        String?
  metadata       Json              @default("{}")
  lastMessageAt  DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages     Message[]
  ticket       Ticket?

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([assignedAgentId])
}

model Message {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String        @db.Uuid
  conversationId String        @db.Uuid
  role           MessageRole
  channel        MessageChannel @default(WEB)
  content        String        @db.Text
  metadata       Json          @default("{}")
  confidence     Float?
  citations      Json          @default("[]")
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments  Attachment[]

  @@index([organizationId, createdAt])
  @@index([conversationId, createdAt])
}

model Attachment {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  messageId      String?  @db.Uuid
  filename       String
  contentType    String
  size           Int
  url            String
  key            String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// =====================================================
// KNOWLEDGE BASE & RAG
// =====================================================

model KnowledgeSource {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                @db.Uuid
  name           String
  type           KnowledgeSourceType
  status         KnowledgeSourceStatus @default(PENDING)
  url            String?
  fileKey        String?
  fileSize       Int?
  contentType    String?
  errorMessage   String?
  chunkCount     Int                   @default(0)
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks       KnowledgeChunk[]

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
}

model KnowledgeChunk {
  id             String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                  @db.Uuid
  sourceId       String                  @db.Uuid
  content        String                  @db.Text
  chunkIndex     Int
  tokenCount     Int                     @default(0)
  metadata       Json                    @default("{}")
  embedding      Unsupported("vector(768)")
  createdAt      DateTime                @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source       KnowledgeSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([sourceId])
}

model Faq {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  question       String   @db.Text
  answer         String   @db.Text
  category       String?
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// =====================================================
// TICKETS
// =====================================================

model Ticket {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String         @db.Uuid
  conversationId String?        @unique @db.Uuid
  number         Int
  title          String
  description    String         @db.Text
  status         TicketStatus   @default(OPEN)
  priority       TicketPriority @default(MEDIUM)
  assigneeId     String?        @db.Uuid
  customerName   String?
  customerEmail  String?
  tags           String[]       @default([])
  metadata       Json           @default("{}")
  resolvedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assignee     User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments     TicketComment[]

  @@unique([organizationId, number])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([assigneeId])
}

model TicketComment {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  ticketId       String   @db.Uuid
  authorId       String   @db.Uuid
  content        String   @db.Text
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt])
}

// =====================================================
// AGENTS & WHATSAPP
// =====================================================

model Agent {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String      @db.Uuid
  userId         String      @unique @db.Uuid
  status         AgentStatus @default(OFFLINE)
  skills         String[]    @default([])
  maxConcurrent  Int         @default(5)
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  statusHistory AgentStatusHistory[]

  @@index([organizationId, status])
}

model AgentStatusHistory {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String      @db.Uuid
  agentId        String      @db.Uuid
  status         AgentStatus
  reason         String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
}

model WhatsappAccount {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  phoneNumber    String
  displayName    String
  isConnected    Boolean  @default(false)
  isMock         Boolean  @default(true)
  webhookUrl     String?
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     WhatsappMessage[]
  campaigns    Campaign[]

  @@index([organizationId])
}

model WhatsappMessage {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  accountId      String   @db.Uuid
  externalId     String
  fromNumber     String
  toNumber       String
  direction      String
  content        String   @db.Text
  status         String   @default("pending")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account      WhatsappAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([accountId])
}

model Campaign {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String         @db.Uuid
  accountId      String         @db.Uuid
  name           String
  status         CampaignStatus @default(DRAFT)
  templateName   String
  messageBody    String         @db.Text
  recipients     Json           @default("[]")
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  sentCount      Int            @default(0)
  deliveredCount Int            @default(0)
  readCount      Int            @default(0)
  failedCount    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account      WhatsappAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

// =====================================================
// NOTIFICATIONS, BILLING, AUDIT
// =====================================================

model Notification {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String           @db.Uuid
  userId         String           @db.Uuid
  type           NotificationType @default(INFO)
  title          String
  body           String           @db.Text
  data           Json             @default("{}")
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([organizationId, createdAt])
}

model ChatbotConfig {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String   @unique @db.Uuid
  name                String   @default("Assistant")
  systemPrompt        String   @db.Text @default("You are a helpful customer support assistant.")
  welcomeMessage      String   @default("Hi! How can I help you today?")
  fallbackMessage     String   @default("I am not sure about that. Let me connect you with a human.")
  escalationKeywords  String[] @default([])
  confidenceThreshold Float    @default(0.7)
  handoffEnabled      Boolean  @default(true)
  settings            Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String             @db.Uuid
  stripeId          String?            @unique
  plan              PlanTier
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organizationId])
  @@index([stripeId])
}

model Invoice {
  id             String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String        @db.Uuid
  subscriptionId String?       @db.Uuid
  stripeId       String?       @unique
  number         String
  status         InvoiceStatus @default(DRAFT)
  amountDue      Int
  amountPaid     Int           @default(0)
  currency       String        @default("usd")
  issuedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([organizationId, status])
}

model AuditLog {
  id             String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String      @db.Uuid
  userId         String?     @db.Uuid
  action         AuditAction
  entity         String
  entityId       String?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, entity, entityId])
}
