NODE_ENV=development
APP_NAME="Neo Support AI"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL="postgresql://neo:neo@localhost:5432/neo?schema=public"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-me-in-prod-use-openssl-rand-base64-32"
JWT_REFRESH_SECRET="change-me-in-prod-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.0-flash"
GEMINI_EMBEDDING_MODEL="text-embedding-004"
EMBEDDING_DIMENSIONS=768

S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="neo"
S3_SECRET_KEY="neo-secret"
S3_BUCKET="neo-uploads"
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL="http://localhost:9000/neo-uploads"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_test_..."
STRIPE_PRICE_STARTER="price_test_starter"
STRIPE_PRICE_PRO="price_test_pro"
STRIPE_PRICE_ENTERPRISE="price_test_enterprise"

SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Neo Support AI <noreply@neo.local>"

WHATSAPP_PROVIDER="mock"
WHATSAPP_WEBHOOK_SECRET="dev-webhook-secret"

FEATURE_BILLING_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_RAG_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true

SENTRY_DSN=""
LOG_LEVEL="info"

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
