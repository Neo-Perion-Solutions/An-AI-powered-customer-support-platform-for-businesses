{
  "name": "neo-support-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered customer support SaaS platform",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "pnpm --filter @neo/api prisma generate",
    "db:migrate": "pnpm --filter @neo/api prisma migrate deploy",
    "db:reset": "pnpm --filter @neo/api prisma migrate reset --force",
    "db:seed": "pnpm --filter @neo/api prisma db seed",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "verify": "bash scripts/verify.sh",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0"
  },
  "packageManager": "pnpm@9.12.1",
  "engines": {
    "node": ">=20.0.0"
  }
}
